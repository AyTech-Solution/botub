# =========================================================================
# BOTUB AI - CONFIGURATION ENVIRONMENT VARIABLES
# =========================================================================
# This file serves as a guide for setting up your local .env file or 
# adding environment variables to your GitHub/Vercel production deployment.
# =========================================================================

# --- Firebase Client Configuration (Frontend) ---
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-firebase-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_DATABASE_ID=your-firestore-database-id-usually-same-as-project-id-or-(default)
VITE_FIREBASE_STORAGE_BUCKET=your-firebase-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-firebase-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-firebase-measurement-id-optional

# --- AI Configuration (Backend/Serverless APIs) ---
# Paste your premium Gemini API key (Required for AI bot chat responses)
GEMINI_API_KEY=your-google-gemini-api-key
# Paste your Groq API key (Used as an automatic high-speed backup model)
GROQ_API_KEY=your-groq-api-key

# --- Mailing Configuration (SMTP) ---
# Used for instant offline email lead capture generation notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-verified-email@gmail.com
SMTP_PASS=your-gmail-secure-app-specific-password
SMTP_SECURE=false

# --- Firebase Backend Administration (Required for secure API server routes) ---
# Download your Service Account credentials json key from Firebase Console 
# (Project Settings > Service Accounts), remove newlines, and paste the entire single-line JSON string:
FIREBASE_SERVICE_ACCOUNT={"type": "service_account", "project_id": "...", ...}
